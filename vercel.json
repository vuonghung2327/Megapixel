{
    "version": 2,
    "builds": [
        { "src": "*.php", "use": "vercel-php@0.6.0" },
        { "src": "admin/*.php", "use": "vercel-php@0.6.0" },
        { "src": "*.css", "use": "@vercel/static" },
        { "src": "*.js", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/admin/", "dest": "/admin/index.php" },
        { "src": "/(.*\\.php)", "dest": "/$1" },
        { "src": "/(.*\\.css)", "dest": "/$1" },
        { "src": "/(.*\\.js)", "dest": "/$1" },
        { "src": "/(.*)", "dest": "/index.php" }
    ]
}
